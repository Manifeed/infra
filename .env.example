POSTGRES_DB=manifeed_content
POSTGRES_USER=manifeed
POSTGRES_PASSWORD=manifeed

TRAEFIK_DEV_HOST=localhost
TRAEFIK_DEV_DASHBOARD_HOST=traefik.localhost
TRAEFIK_DEV_CERT_DAYS=825

CORS_ORIGINS=http://localhost
PUBLIC_API_ALLOWED_HOSTS=public_api,manifeed_public_api

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=article_embeddings
SOURCE_EMBEDDING_DIMENSIONS=1024

ADMIN_SERVICE_REPO_PATH=../admin_service
CONTENT_SERVICE_REPO_PATH=../content_service
AUTH_SERVICE_REPO_PATH=../auth_service
USER_SERVICE_REPO_PATH=../user_service
WORKER_SERVICE_REPO_PATH=../worker_service
FRONTEND_REPO_PATH=../frontend
RSS_FEEDS_HOST_PATH=../../rss_feeds

AUTH_SERVICE_URL=http://auth_service:8000
USER_SERVICE_URL=http://user_service:8000
ADMIN_SERVICE_URL=http://admin_service:8000
CONTENT_SERVICE_URL=http://content_service:8000
WORKER_SERVICE_URL=http://worker_service:8000

INTERNAL_SERVICE_TOKEN=change-me-in-production-with-at-least-32-chars
AUTH_SERVICE_DB_POOL_SIZE=5
AUTH_SERVICE_DB_MAX_OVERFLOW=10
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=300
